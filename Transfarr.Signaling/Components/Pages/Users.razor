@page "/users"
@using Transfarr.Signaling.Data
@using Microsoft.AspNetCore.SignalR
@using Transfarr.Signaling.Hubs
@using Transfarr.Signaling.Services
@inject UserDatabase Db
@inject IHubContext<SignalingHub> HubContext
@inject NetworkStateService NetworkState

<PageTitle>User Management - Transfarr Hub</PageTitle>

<div style="max-width: 1000px; margin: 0 auto;">
    <div style="margin-bottom: 32px; display: flex; align-items: center; justify-content: space-between;">
        <div>
            <h2 style="font-size: 24px; font-weight: 300; color: var(--text-highlight); margin: 0 0 8px 0;">User Administration</h2>
            <p style="color: var(--text-muted); font-size: 13px; margin: 0;">Manage network nodes, assigned roles, and reputation status.</p>
        </div>
        
        <div class="panel" style="padding: 16px; display: flex; gap: 12px; align-items: center;">
            <input @bind="_newUsername" @bind:event="oninput" placeholder="Username" class="input-clean" style="width: 140px;" />
            <input @bind="_newPassword" @bind:event="oninput" type="password" placeholder="Password" class="input-clean" style="width: 140px;" />
            <button @onclick="CreateUser" class="btn-clean">ADD USER</button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_message))
    {
        <div style="margin-bottom: 24px; padding: 12px 20px; background: rgba(14, 99, 156, 0.1); border-left: 4px solid var(--accent-blue); color: var(--text-highlight); font-size: 13px;">
            @_message
        </div>
    }

    <div class="panel" style="overflow: hidden;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>USERNAME</th>
                    <th>ROLE</th>
                    <th>REPUTATION (pts)</th>
                    <th style="text-align: right;">OPERATIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var username in _users)
                {
                    var user = Db.GetUser(username);
                    <tr>
                        <td style="color: var(--text-highlight); font-weight: 600;">@username</td>
                        <td>
                            <span class="badge-clean @(user?.Role == "Admin" ? "badge-red" : "badge-blue")">@user?.Role</span>
                        </td>
                        <td>
                            <span style="color: var(--accent-yellow); font-weight: 600;">@GetReputation(username)</span>
                        </td>
                        <td style="text-align: right;">
                            @if (username != "admin")
                            {
                                var suspended = user?.IsSuspended ?? false;
                                <button @onclick="() => ToggleSuspension(username, suspended)" 
                                        class="btn-clean" 
                                        style="background: transparent; border: 1px solid @(suspended ? "var(--accent-blue)" : "var(--border-color)"); color: @(suspended ? "var(--accent-blue)" : "var(--text-muted)"); font-size: 10px;">
                                    @(suspended ? "UNSUSPEND" : "SUSPEND")
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<string> _users = new();
    private string _newUsername = "";
    private string _newPassword = "";
    private string _message = "";

    protected override void OnInitialized()
    {
        RefreshList();
    }

    private void RefreshList()
    {
        _users = Db.GetAllUsernames();
    }

    private int GetReputation(string username)
    {
        var user = Db.GetUser(username);
        return user?.Reputation ?? 0;
    }

    private async Task ToggleSuspension(string username, bool current)
    {
        bool nextStatus = !current;
        Db.SetSuspension(username, nextStatus);
        
        if (nextStatus)
        {
            // If we are suspending, kick the user if they are online
            var onlinePeers = NetworkState.ActivePeers.Where(p => p.Name == username).ToList();
            foreach (var peer in onlinePeers)
            {
                await HubContext.Clients.Client(peer.ConnectionId).SendAsync("OnSuspended");
                // The client should disconnect itself, but we can also stop the connection server-side
                // Note: SignalR doesn't have a direct "DisconnectClient" on IHubContext easily, 
                // but we can send a message that triggers it, or let the hub filter handle it.
            }
            _message = $"User {username} suspended and kicked.";
        }
        else
        {
            _message = $"User {username} unsuspended.";
        }
        
        RefreshList();
    }

    private void CreateUser()
    {
        if (string.IsNullOrWhiteSpace(_newUsername) || string.IsNullOrWhiteSpace(_newPassword))
        {
            _message = "Username and password required.";
            return;
        }

        string hash = BCrypt.Net.BCrypt.HashPassword(_newPassword);
        if (Db.CreateUser(_newUsername, hash))
        {
            _message = $"User {_newUsername} successfully provisioned.";
            _newUsername = "";
            _newPassword = "";
            RefreshList();
        }
        else
        {
            _message = "ERR: Failed to create user identity. Alias may be taken.";
        }
    }
}
