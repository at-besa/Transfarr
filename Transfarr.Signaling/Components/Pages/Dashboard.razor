@page "/"
@using Transfarr.Signaling.Services
@inject NetworkStateService NetworkState
@implements IDisposable

<PageTitle>Dashboard - Transfarr Hub</PageTitle>

<div style="max-width: 1200px; margin: 0 auto;">
    <div style="margin-bottom: 32px;">
        <h2 style="font-size: 24px; font-weight: 300; color: var(--text-highlight); margin: 0 0 8px 0;">Network Overview</h2>
        <p style="color: var(--text-muted); font-size: 13px; margin: 0;">Real-time signaling and performance metrics for the active cluster.</p>
    </div>

    <!-- Metrics Grid -->
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px;">
        <div class="stat-card">
            <div class="stat-label">Active Nodes</div>
            <div class="stat-value">@NetworkState.GetActiveNodeCount()</div>
            <div class="stat-sub">Peak: @NetworkState.PeakUserCount concurrent</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Network Share</div>
            <div class="stat-value">@FormatSize(NetworkState.GetTotalSharedBytes())</div>
            <div class="stat-sub">Peak: @FormatSize(NetworkState.PeakTotalSharedBytes)</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Global Rate</div>
            <div class="stat-value">@FormatRate(NetworkState.CurrentTransferRateBps)</div>
            <div class="stat-sub">Across @NetworkState.GetActiveNodeCount() verified nodes</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">System Uptime</div>
            <div class="stat-value">@_uptime</div>
            <div class="stat-sub">Started @NetworkState.StartupTime.ToLocalTime().ToString("MMM dd, HH:mm")</div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px;">
        <div class="stat-card">
            <div class="stat-label">Total Volume</div>
            <div class="stat-value" style="font-size: 18px;">@FormatSize(NetworkState.TotalBytesTransferred)</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Login Success</div>
            <div class="stat-value" style="font-size: 18px; color: var(--accent-green);">@NetworkState.LoginAttempts</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Error Count</div>
            <div class="stat-value" style="font-size: 18px; color: var(--accent-red);">@NetworkState.TotalErrors</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Avg Share / Node</div>
            <div class="stat-value" style="font-size: 18px;">@GetAvgShare()</div>
        </div>
    </div>

    <!-- Peers Table -->
    <div style="margin-bottom: 40px;">
        <div style="margin-bottom: 16px; display: flex; align-items: center; justify-content: space-between;">
            <h3 style="font-size: 16px; font-weight: 500; color: var(--text-highlight); margin: 0;">Connected Verified Peers</h3>
            <span class="badge-clean badge-blue">ALL CLUSTERS</span>
        </div>
        <div class="panel" style="overflow: hidden;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>PEER NAME</th>
                        <th>IP ADDRESS</th>
                        <th>SHARED SIZE</th>
                        <th>CONNECTED SINCE</th>
                        <th style="text-align: right;">STATUS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var peer in NetworkState.ActivePeers)
                    {
                        <tr>
                            <td style="color: var(--text-highlight); font-weight: 600;">@peer.Name</td>
                            <td style="font-family: monospace; font-size: 12px;">@peer.DirectIp</td>
                            <td>@FormatSize(peer.SharedBytes)</td>
                            <td style="color: var(--text-muted);">Dynamic</td>
                            <td style="text-align: right;">
                                @if (peer.IsPassive)
                                {
                                    <span class="badge-clean badge-red" style="margin-right: 8px;">PASSIVE</span>
                                }
                                else
                                {
                                    <span class="badge-clean badge-blue" style="margin-right: 8px;">ACTIVE</span>
                                }
                                <span class="badge-clean badge-green">VERIFIED</span>
                            </td>
                        </tr>
                    }
                    @if (!NetworkState.ActivePeers.Any())
                    {
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 40px; color: var(--text-muted);">No peers currently connected to the signaling hub.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private System.Threading.Timer? _timer;
    private string _uptime = "00:00:00";

    protected override void OnInitialized()
    {
        _timer = new System.Threading.Timer(_ => 
        {
            var span = DateTime.UtcNow - NetworkState.StartupTime;
            _uptime = $"{(int)span.TotalHours:D2}:{span.Minutes:D2}:{span.Seconds:D2}";
            InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    private string FormatSize(long bytes)
    {
        string[] suffix = { "B", "KB", "MB", "GB", "TB" };
        int i = 0;
        double dS = bytes;
        if (bytes > 1024)
            for (i = 0; (bytes / 1024) > 0 && i < suffix.Length - 1; i++, bytes /= 1024)
                dS = bytes / 1024.0;
        return $"{dS:0.##} {suffix[i]}";
    }

    private string FormatRate(long bps)
    {
        return $"{FormatSize(bps)}/s";
    }

    private string GetAvgShare()
    {
        var count = NetworkState.GetActiveNodeCount();
        if (count == 0) return "0 B";
        return FormatSize(NetworkState.GetTotalSharedBytes() / count);
    }

    public void Dispose() => _timer?.Dispose();
}
