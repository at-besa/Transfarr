@inherits LayoutComponentBase

<div class="page" style="display: flex; height: 100vh;">
    <!-- Sidebar -->
    <div class="sidebar" style="width: 240px; background-color: var(--bg-panel); border-right: 1px solid var(--border-color); display: flex; flex-direction: column;">
        <div style="padding: 24px; border-bottom: 1px solid var(--border-color); display: flex; align-items: center; gap: 12px;">
            <div style="width: 32px; height: 32px; background: var(--accent-blue); border-radius: 6px; display: flex; align-items: center; justify-content: center; font-weight: bold; color: white;">T</div>
            <div>
                <div style="font-size: 14px; font-weight: 600; color: var(--text-highlight);">Transfarr</div>
                <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px;">Signaling Hub</div>
            </div>
        </div>

        <nav style="flex: 1; padding-top: 16px;">
            <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                <span style="font-size: 16px;">📊</span> Dashboard
            </NavLink>
            <NavLink class="nav-item" href="users">
                <span style="font-size: 16px;">👥</span> User Management
            </NavLink>
        </nav>

        <div style="padding: 16px; border-top: 1px solid var(--border-color); font-size: 11px; color: var(--text-muted);">
            Hub v1.0.0-alpha<br />
            © 2026 at-besa
        </div>
    </div>

    <!-- Main Content -->
    <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; background-color: var(--bg-app);">
        <div class="top-bar">
            <div style="font-weight: 600; color: var(--text-highlight);">ADMIN CONSOLE</div>
            <div class="d-flex align-items-center gap-3">
                <span class="badge-clean badge-blue">CONNECTED</span>
                <div style="width: 32px; height: 32px; border-radius: 50%; background: #444; display: flex; align-items: center; justify-content: center; font-size: 14px;">A</div>
            </div>
        </div>

        <div style="flex: 1; overflow-y: auto; padding: 32px;">
            @Body
        </div>
    </div>
</div>

<style>
    .nav-item {
        padding: 12px 24px;
        color: var(--text-muted);
        text-decoration: none !important;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 13px;
        font-weight: 500;
        transition: all 0.2s ease;
    }
    .nav-item:hover {
        color: var(--text-highlight);
        background-color: var(--bg-hover);
    }
    .nav-item.active {
        color: var(--text-highlight);
        background-color: var(--bg-active);
        border-left: 3px solid var(--accent-blue);
    }
</style>
