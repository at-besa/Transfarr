{
  "Transfarr": {
    "NodePort": 5150,
    "DefaultHubUrls": [
      "http://localhost:5135/signaling"
    ],
    "DefaultNodeName": "Transfarr-Node-Alpha",
    "DatabasePath": "shares.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "P2PSettings": {
    "EnableUPnP": true,
    "StunServers": [
      "stun.l.google.com:19302",
      "stun1.l.google.com:19302"
    ]
  },
  "AllowedHosts": "*"
}
