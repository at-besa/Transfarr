@using Transfarr.Client.Core.Services
@using Transfarr.Shared.Models
@inject ConnectionManager Connection
@implements IDisposable

<div style="padding:12px 16px; border-bottom:1px solid var(--border-color); background-color:var(--bg-panel);">
    <h3 style="font-size:11px; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.5px; margin:0; display:flex; align-items:center; gap:6px;">
        <span style="width:6px; height:6px; background:#40c057; border-radius:50%;"></span>
        Online Network (@Connection.OnlinePeers.Count)
    </h3>
</div>

<div style="flex:1; overflow-y:auto; padding:8px 0; background-color:var(--bg-panel);">
    @foreach (var peer in Connection.OnlinePeers)
    {
        var isMe = Connection.LocalPeer != null && peer.PeerId == Connection.LocalPeer.PeerId;

        <div class="list-item" style="padding:10px 16px; position:relative; cursor:pointer; background-color:@(isMe ? "rgba(64, 192, 87, 0.03)" : "transparent");" @onclick="() => ToggleMenu(peer.PeerId)">
            <div style="display:flex; justify-content:space-between; align-items:center; width:100%;">
                <div style="display:flex; align-items:center; gap:8px;">
                    <span class="status-dot status-online"></span>
                    <span style="font-size:13px; font-weight:500; color:@(isMe ? "#40c057" : "var(--text-highlight)");">
                        @peer.Name
                        @if (isMe)
                        {
                            <span style="font-size:9px; background:#40c057; color:white; padding:1px 4px; border-radius:2px; margin-left:4px; vertical-align:middle;">YOU</span>
                        }
                    </span>
                </div>
                <span style="font-size:11px; color:var(--text-muted);">@FormatBytes(peer.SharedBytes)</span>
            </div>
            
            @if (_openMenuPeerId == peer.PeerId)
            {
                <div style="position:absolute; right:10px; top:100%; margin-top:4px; background-color:var(--bg-panel); border:1px solid var(--border-color); border-radius:4px; padding:4px 0; z-index:1000; box-shadow:0 8px 24px rgba(0,0,0,0.6); min-width:180px;" @onclick:stopPropagation>
                    <div style="padding:8px 16px; font-size:11px; color:var(--text-muted); border-bottom:1px solid var(--border-color); margin-bottom:4px; text-transform:uppercase; letter-spacing:0.5px;">
                        @(isMe ? "Node Control" : "Peer Actions")
                    </div>
                    
                    <div class="list-item-action" style="padding:8px 16px; color:var(--text-highlight); font-size:13px; display:flex; align-items:center; gap:10px;" @onclick="() => { RequestFileList(peer); ToggleMenu(null); }">
                        <span>📁</span> @(isMe ? "My Filelist" : "Browse Filelist")
                    </div>

                    @if (!isMe)
                    {
                        <div class="list-item-action" style="padding:8px 16px; color:var(--text-highlight); font-size:13px; display:flex; align-items:center; gap:10px;" @onclick="() => { OpenPrivateChat(peer); ToggleMenu(null); }">
                            <span>💬</span> Send Message
                        </div>
                        
                        <div class="list-item-action" style="padding:8px 16px; color:var(--text-highlight); font-size:13px; display:flex; align-items:center; gap:10px;" @onclick="() => { ConnectPeer(peer); ToggleMenu(null); }">
                            <span>🔌</span> Connect P2P
                        </div>
                    }
                </div>
            }
        </div>
    }
    @if (!Connection.OnlinePeers.Any())
    {
        <div style="padding:32px 16px; text-align:center; color:var(--text-muted); font-size:12px; font-style:italic;">
            Connecting to network...
        </div>
    }
</div>

<style>
    .list-item-action:hover {
        background-color: var(--bg-active);
        color: white !important;
    }
</style>

@code {
    [Parameter] public EventCallback<PeerInfo> OnRequestFileList { get; set; }
    [Parameter] public EventCallback<PeerInfo> OnOpenPrivateChat { get; set; }
    
    private string? _openMenuPeerId;

    protected override void OnInitialized()
    {
        Connection.OnStateChanged += Refresh;
    }

    private void Refresh() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Connection.OnStateChanged -= Refresh;
    }
    
    private void ToggleMenu(string? peerId)
    {
        if (_openMenuPeerId == peerId) _openMenuPeerId = null;
        else _openMenuPeerId = peerId;
    }

    private Task RequestFileList(PeerInfo peer)
    {
        return OnRequestFileList.InvokeAsync(peer);
    }
    
    private void ConnectPeer(PeerInfo peer)
    {
        if (!Connection.ConnectedPeers.Contains(peer.PeerId))
        {
            _ = Connection.ConnectToPeer(peer.PeerId);
        }
    }

    private void OpenPrivateChat(PeerInfo peer)
    {
        OnOpenPrivateChat.InvokeAsync(peer);
    }

    private string FormatBytes(long bytes)
    {
        if (bytes == 0) return "0 B";
        string[] suffix = { "B", "KB", "MB", "GB", "TB" };
        int i = 0;
        double dS = bytes;
        if (bytes > 1024)
            for (i = 0; (bytes / 1024) > 0 && i < suffix.Length - 1; i++, bytes /= 1024)
                dS = bytes / 1024.0;
        return $"{dS:0.##} {suffix[i]}";
    }
}
